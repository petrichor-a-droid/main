{% comment %}
  Petrichor Atelier — Collection Row
  Secondary 3-column product grid with eyebrow + heading header.
  Mirrors the "second product row" section in Storefront.jsx.
{% endcomment %}

{%- liquid
  assign col        = collections[section.settings.collection]
  assign prod_limit = section.settings.products_to_show | default: 3
-%}

<style>
  #shopify-section-{{ section.id }} .pa-cr {
    padding: 120px 0 80px;
    background: var(--bg-canvas);
  }

  #shopify-section-{{ section.id }} .pa-cr__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .pa-cr__header {
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .pa-cr__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-3);
  }

  #shopify-section-{{ section.id }} .pa-cr__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: clamp(32px, 3.8vw, 48px);
    line-height: var(--lh-heading);
    letter-spacing: -0.012em;
    margin: 12px 0 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-cr__heading em,
  #shopify-section-{{ section.id }} .pa-cr__heading i {
    font-family: var(--font-editorial);
    font-style: italic;
  }

  /* ── Grid ── */
  #shopify-section-{{ section.id }} .pa-cr__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  /* ── Product card ── */
  #shopify-section-{{ section.id }} .pa-cr__card {
    display: block;
    text-decoration: none;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-cr__card-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--bg-surface);
  }

  #shopify-section-{{ section.id }} .pa-cr__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  #shopify-section-{{ section.id }} .pa-cr__card:hover .pa-cr__card-img {
    transform: scale(1.03);
  }

  #shopify-section-{{ section.id }} .pa-cr__card-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    background: var(--bg-surface);
  }

  #shopify-section-{{ section.id }} .pa-cr__card-body {
    padding-top: 16px;
  }

  #shopify-section-{{ section.id }} .pa-cr__card-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .pa-cr__card-vendor {
    display: block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: var(--fw-medium);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 4px;
  }

  #shopify-section-{{ section.id }} .pa-cr__card-title {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: var(--ls-heading);
    margin: 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-cr__card-price {
    font-family: var(--font-body);
    font-size: var(--t-body-sm);
    color: var(--fg-1);
    white-space: nowrap;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .pa-cr__card-price s {
    opacity: 0.5;
    margin-left: 6px;
  }

  #shopify-section-{{ section.id }} .pa-cr__card-notes {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--fg-2);
    margin: 6px 0 0;
    line-height: 1.4;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .pa-cr__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .pa-cr {
      padding: 80px 0 56px;
    }
    #shopify-section-{{ section.id }} .pa-cr__inner {
      padding: 0 var(--gutter-mobile, 20px);
    }
    #shopify-section-{{ section.id }} .pa-cr__header {
      margin-bottom: 32px;
    }
  }
</style>

<div class="pa-cr">
  <div class="pa-cr__inner">

    <div class="pa-cr__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="pa-cr__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-cr__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="pa-cr__grid">
      {%- for product in col.products limit: prod_limit -%}
        <a href="{{ product.url }}" class="pa-cr__card">
          <div class="pa-cr__card-img-wrap">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 1000
                | image_tag:
                  class: 'pa-cr__card-img',
                  widths: '500, 700, 1000',
                  sizes: '(max-width: 749px) calc(50vw - 30px), (max-width: 989px) calc(50vw - 54px), 33vw',
                  loading: 'lazy',
                  alt: product.featured_image.alt | default: product.title | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'pa-cr__card-placeholder' }}
            {%- endif -%}
          </div>

          <div class="pa-cr__card-body">
            <div class="pa-cr__card-meta">
              <div>
                {%- if product.vendor != blank -%}
                  <span class="pa-cr__card-vendor">{{ product.vendor | escape }}</span>
                {%- endif -%}
                <h3 class="pa-cr__card-title">{{ product.title | escape }}</h3>
              </div>
              <div class="pa-cr__card-price">
                {%- if product.compare_at_price > product.price -%}
                  {{ product.price | money }}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </div>
            </div>
            {%- assign card_notes = product.metafields.custom.notes.value -%}
            {%- if card_notes != blank -%}
              <p class="pa-cr__card-notes">{{ card_notes | escape }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..prod_limit) -%}
          <div class="pa-cr__card">
            <div class="pa-cr__card-img-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'pa-cr__card-placeholder' }}
            </div>
            <div class="pa-cr__card-body">
              <div class="pa-cr__card-meta">
                <div>
                  <span class="pa-cr__card-vendor">Vendor</span>
                  <h3 class="pa-cr__card-title">Product name</h3>
                </div>
                <div class="pa-cr__card-price">{{ 1999 | money }}</div>
              </div>
              <p class="pa-cr__card-notes">Notes</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "PA — Collection Row",
  "tag": "section",
  "class": "section-pa-collection-row",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Products to show",
      "default": 3
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Discovery · 03"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "For the curious.",
      "info": "Use italic in the editor for the editorial serif style."
    }
  ],
  "presets": [
    {
      "name": "PA — Collection Row"
    }
  ]
}
{% endschema %}

