{% comment %}
  Petrichor Atelier — Collection Row
  Secondary 3-column product grid with eyebrow + heading header.
  Mirrors the "second product row" section in Storefront.jsx.
{% endcomment %}

{{ 'pa-product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign col        = collections[section.settings.collection]
  assign prod_limit = section.settings.products_to_show | default: 3
-%}

<style>
  #shopify-section-{{ section.id }} .pa-cr {
    padding: 120px 0 80px;
    background: var(--bg-canvas);
  }

  #shopify-section-{{ section.id }} .pa-cr__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  /* ── Header ── */
  #shopify-section-{{ section.id }} .pa-cr__header {
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .pa-cr__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-3);
  }

  #shopify-section-{{ section.id }} .pa-cr__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: clamp(32px, 3.8vw, 48px);
    line-height: var(--lh-heading);
    letter-spacing: -0.012em;
    margin: 12px 0 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-cr__heading em,
  #shopify-section-{{ section.id }} .pa-cr__heading i {
    font-family: var(--font-editorial);
    font-style: italic;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .pa-cr {
      padding: 80px 0 56px;
    }
    #shopify-section-{{ section.id }} .pa-cr__inner {
      padding: 0 var(--gutter-mobile, 20px);
    }
    #shopify-section-{{ section.id }} .pa-cr__header {
      margin-bottom: 32px;
    }
  }
</style>

<div class="pa-cr">
  <div class="pa-cr__inner">

    <div class="pa-cr__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="pa-cr__eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="pa-cr__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="pa-fc__grid" style="--pa-grid-cols: 3;">
      {%- for product in col.products limit: prod_limit -%}
        {%- render 'pa-product-card', card_product: product, loading: 'lazy',
          sizes: '(max-width: 749px) calc(50vw - 20px), (max-width: 989px) calc(50vw - 40px), 33vw' -%}
      {%- else -%}
        {%- for i in (1..prod_limit) -%}
          {%- render 'pa-product-card' -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "PA — Collection Row",
  "tag": "section",
  "class": "section-pa-collection-row",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Products to show",
      "default": 3
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Discovery · 03"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "For the curious.",
      "info": "Use italic in the editor for the editorial serif style."
    }
  ],
  "presets": [
    {
      "name": "PA — Collection Row"
    }
  ]
}
{% endschema %}

