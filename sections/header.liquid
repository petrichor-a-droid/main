{%- liquid
  assign nav_list  = section.settings.menu | default: 'main-menu'
  assign nav_links = linklists[nav_list].links
-%}

<style>
  /* ================================================================
     Petrichor Atelier — Site Header
     Hex fallbacks on every token so the header renders even if
     petrichor-tokens.css hasn't been uploaded yet.
     ================================================================ */

  .pa-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 300;
    background: var(--pa-ivory, #f9f8f4);
    color: var(--pa-ink, #1d1d1b);
    border-bottom: 1px solid var(--border-soft, #e3ddd1);
    transition:
      background      240ms ease,
      border-color    240ms ease,
      backdrop-filter 240ms ease;
  }

  .pa-header.is-scrolled {
    background: var(--pa-ivory, #f9f8f4);
    border-bottom-color: var(--border-soft, #e3ddd1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* Transparent variant — used when hero banner is first section */
  .pa-header.pa-header--transparent {
    background: transparent;
    border-bottom-color: transparent;
  }

  /* Switch text to ivory when floating over a dark hero */
  .pa-header--transparent:not(.is-scrolled) {
    color: var(--pa-ivory, #f9f8f4);
  }

  /* When the user has scrolled, always override the transparent state —
     this rule has higher specificity (0,3,0) than either class alone */
  .pa-header.pa-header--transparent.is-scrolled {
    background: var(--pa-ivory, #f9f8f4);
    border-bottom-color: var(--border-soft, #e3ddd1);
    color: var(--pa-ink, #1d1d1b);
  }

  .pa-header__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  @media (max-width: 749px) {
    .pa-header__inner { padding: 0 var(--gutter-mobile, 20px); }
  }

  /* ── Row 1: utility nav ── */

  .pa-header__row--utility {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 24px;
    padding: 14px 0 12px;
  }

  .pa-header__nav,
  .pa-header__util {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .pa-header__link {
    font-family: var(--font-body, 'Instrument Sans', 'Helvetica Neue', sans-serif);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.01em;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 160ms ease;
  }

  .pa-header__link:hover         { opacity: 0.55; }
  .pa-header__link[aria-current] { opacity: 0.45; }

  .pa-header__cart-count { opacity: 0.65; }

  /* ── Row 2: centred logo ── */

  .pa-header__row--logo {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4px 0 18px;
  }

  .pa-header__logo-wrap {
    margin: 0;
    padding: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: 1;
  }

  .pa-header__logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .pa-header__logo {
    height: 18px;
    width: auto;
    display: block;
  }

  .pa-header__logo--light { display: none; }
  .pa-header--transparent:not(.is-scrolled) .pa-header__logo--dark { display: none; }
  .pa-header--transparent:not(.is-scrolled) .pa-header__logo--light { display: block; }

  /* ── Mobile ── */

  .pa-header__mob-left,
  .pa-header__mob-right { display: none; }

  @media (max-width: 989px) {
    .pa-header__nav,
    .pa-header__util              { display: none; }
    .pa-header__row--utility      { grid-template-columns: auto 1fr auto; }
    .pa-header__mob-left,
    .pa-header__mob-right         { display: flex; align-items: center; }
  }

  /* Push page content below the fixed header.
     80px is a safe fallback until JS measures the real height. */
  body { padding-top: var(--pa-header-height, 80px); }
</style>

<div id="pa-site-header" class="pa-header" role="banner">
  <div class="pa-header__inner">

    <!-- ── Row 1: utility nav ── -->
    <div class="pa-header__row--utility">

      <!-- Mobile: hamburger -->
      <button
        class="pa-header__link pa-header__mob-left"
        type="button"
        aria-label="{{ 'sections.header.menu' | t }}"
        onclick="document.querySelector('header-drawer details')?.setAttribute('open','')"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <line x1="4" x2="20" y1="6"  y2="6"/>
          <line x1="4" x2="20" y1="12" y2="12"/>
          <line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
      </button>

      <!-- Desktop: primary nav + search -->
      <nav class="pa-header__nav" aria-label="Primary navigation">
        {%- for link in nav_links -%}
          <a
            href="{{ link.url }}"
            class="pa-header__link"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- endfor -%}

        <!-- Lucide search — 13px / 1.5 stroke -->
        <a href="{{ routes.search_url }}" class="pa-header__link" aria-label="{{ 'general.search.search' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          Search
        </a>
      </nav>

      <!-- Desktop: utility + cart -->
      <div class="pa-header__util">
        <a href="{{ routes.root_url }}pages/contact" class="pa-header__link">Contact</a>

        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="pa-header__link"
            rel="nofollow"
          >Account</a>
        {%- endif -%}

        <a href="/pages/wishlist" class="pa-header__link">Wishlist (0)</a>

        <a href="{{ routes.cart_url }}" class="pa-header__link" id="pa-cart-icon">
          Bag{%- if cart.item_count > 0 -%}<span class="pa-header__cart-count"> ({{ cart.item_count }})</span>{%- endif -%}
        </a>
      </div>

      <!-- Mobile: cart only -->
      <a
        href="{{ routes.cart_url }}"
        class="pa-header__link pa-header__mob-right"
        aria-label="{{ 'templates.cart.cart' | t }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="pa-header__cart-count" aria-hidden="true">({{ cart.item_count }})</span>
        {%- endif -%}
      </a>

    </div><!-- /row--utility -->

    <!-- ── Row 2: centred logo ── -->
    <div class="pa-header__row--logo">
      {%- if request.page_type == 'index' -%}
        <h1 class="pa-header__logo-wrap">
      {%- else -%}
        <div class="pa-header__logo-wrap">
      {%- endif -%}

        <a href="{{ routes.root_url }}" class="pa-header__logo-link">
          <img src="{{ 'primary-logo-cocoa.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--dark"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
          <img src="{{ 'primary-logo-ivory.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--light"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
        </a>

      {%- if request.page_type == 'index' -%}
        </h1>
      {%- else -%}
        </div>
      {%- endif -%}
    </div><!-- /row--logo -->

  </div><!-- /pa-header__inner -->
</div><!-- /pa-header -->

<script>
  (function () {
    var header = document.getElementById('pa-site-header');
    if (!header) return;

    function setHeight() {
      var h = header.offsetHeight + 'px';
      document.documentElement.style.setProperty('--pa-header-height', h);
      document.documentElement.style.setProperty('--header-height', h);
    }

    function onScroll() {
      header.classList.toggle('is-scrolled', window.scrollY > 10);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', setHeight);
    onScroll();
    setHeight();
  })();
</script>

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {%- assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header",
  "max_blocks": 3,
  "settings": [
    {
      "type": "select",
      "id": "logo_position",
      "options": [
        {
          "value": "top-left",
          "label": "t:sections.header.settings.logo_position.options__2.label"
        },
        {
          "value": "top-center",
          "label": "t:sections.header.settings.logo_position.options__3.label"
        },
        {
          "value": "middle-left",
          "label": "t:sections.header.settings.logo_position.options__1.label"
        },
        {
          "value": "middle-center",
          "label": "t:sections.header.settings.logo_position.options__4.label"
        }
      ],
      "default": "middle-left",
      "label": "t:sections.header.settings.logo_position.label",
      "info": "t:sections.header.settings.logo_help.content"
    },
    {
      "type": "select",
      "id": "mobile_logo_position",
      "options": [
        {
          "value": "center",
          "label": "t:sections.header.settings.mobile_logo_position.options__1.label"
        },
        {
          "value": "left",
          "label": "t:sections.header.settings.mobile_logo_position.options__2.label"
        }
      ],
      "default": "center",
      "label": "t:sections.header.settings.mobile_logo_position.label"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        {
          "value": "dropdown",
          "label": "t:sections.header.settings.menu_type_desktop.options__1.label"
        },
        {
          "value": "mega",
          "label": "t:sections.header.settings.menu_type_desktop.options__2.label"
        },
        {
          "value": "drawer",
          "label": "t:sections.header.settings.menu_type_desktop.options__3.label"
        }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label"
    },
    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        {
          "value": "none",
          "label": "t:sections.header.settings.sticky_header_type.options__1.label"
        },
        {
          "value": "on-scroll-up",
          "label": "t:sections.header.settings.sticky_header_type.options__2.label"
        },
        {
          "value": "always",
          "label": "t:sections.header.settings.sticky_header_type.options__3.label"
        },
        {
          "value": "reduce-logo-size",
          "label": "t:sections.header.settings.sticky_header_type.options__4.label"
        }
      ],
      "default": "on-scroll-up",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__1.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "t:sections.header.settings.menu_color_scheme.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__utilities.content"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_country_selector.label",
      "info": "t:sections.header.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.header.settings.enable_language_selector.label",
      "info": "t:sections.header.settings.enable_language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_customer_avatar",
      "default": true,
      "label": "t:sections.header.settings.enable_customer_avatar.label",
      "info": "t:sections.header.settings.enable_customer_avatar.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.header.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 36,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
