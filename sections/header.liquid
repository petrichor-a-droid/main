{%- liquid
  assign nav_list  = section.settings.menu | default: 'main-menu'
  assign nav_links = linklists[nav_list].links
-%}

<style>
  /* ================================================================
     Petrichor Atelier — Site Header
     Hex fallbacks on every token so the header renders even if
     petrichor-tokens.css hasn't been uploaded yet.
     ================================================================ */

  .pa-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 300;
    background: var(--pa-ivory, #f9f8f4);
    color: var(--pa-ink, #1d1d1b);
    border-bottom: 1px solid var(--border-soft, #e3ddd1);
    transition:
      background      240ms ease,
      border-color    240ms ease,
      backdrop-filter 240ms ease;
  }

  .pa-header.is-scrolled {
    background: rgba(249, 248, 244, 0.88);
    border-bottom-color: var(--border-soft, #e3ddd1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  /* Transparent variant — used when hero banner is first section */
  .pa-header.pa-header--transparent {
    background: transparent;
    border-bottom-color: transparent;
  }

  /* Switch text to ivory when floating over a dark hero */
  .pa-header--transparent:not(.is-scrolled) {
    color: var(--pa-ivory, #f9f8f4);
  }

  /* When the user has scrolled, always override the transparent state —
     this rule has higher specificity (0,3,0) than either class alone */
  .pa-header.pa-header--transparent.is-scrolled {
    background: rgba(249, 248, 244, 0.88);
    border-bottom-color: var(--border-soft, #e3ddd1);
    color: var(--pa-ink, #1d1d1b);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .pa-header__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  @media (max-width: 749px) {
    .pa-header__inner { padding: 0 var(--gutter-mobile, 20px); }
  }

  /* ── Row 1: utility nav ── */

  .pa-header__row--utility {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 24px;
    padding: 14px 0 12px;
  }

  .pa-header__nav,
  .pa-header__util {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .pa-header__util {
    justify-content: flex-end;
  }

  .pa-header__link {
    font-family: var(--font-body, 'Instrument Sans', 'Helvetica Neue', sans-serif);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.01em;
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: opacity 160ms ease;
  }

  .pa-header__link:hover         { opacity: 0.55; }
  .pa-header__link[aria-current] { opacity: 0.45; }

  .pa-header__cart-count { opacity: 0.65; }

  /* ── Row 2: centred logo ── */

  .pa-header__row--logo {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 4px 0 18px;
  }

  .pa-header__logo-wrap {
    margin: 0;
    padding: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: 1;
  }

  .pa-header__logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .pa-header__logo {
    height: 18px;
    width: auto;
    display: block;
  }

  .pa-header__logo--light { display: none; }
  .pa-header--transparent:not(.is-scrolled) .pa-header__logo--dark { display: none; }
  .pa-header--transparent:not(.is-scrolled) .pa-header__logo--light { display: block; }

  /* Mobile logo slot — hidden on desktop */
  .pa-header__mob-logo { display: none; }

  /* CSS-native fallback: hero present → transparent until scrolled, frosted-glass after */
  body:has(.section-pa-hero) .pa-header:not(.is-scrolled) {
    background: transparent;
    border-bottom-color: transparent;
    color: var(--pa-ivory, #f9f8f4);
  }
  body:has(.section-pa-hero) .pa-header:not(.is-scrolled) .pa-header__logo--dark { display: none; }
  body:has(.section-pa-hero) .pa-header:not(.is-scrolled) .pa-header__logo--light { display: block; }

  body:has(.section-pa-hero) .pa-header.is-scrolled {
    background: rgba(249, 248, 244, 0.88);
    border-bottom-color: var(--border-soft, #e3ddd1);
    color: var(--pa-ink, #1d1d1b);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  body:has(.section-pa-hero) .pa-header.is-scrolled .pa-header__logo--dark { display: block; }
  body:has(.section-pa-hero) .pa-header.is-scrolled .pa-header__logo--light { display: none; }

  /* ── Mobile ── */

  .pa-header__mob-left,
  .pa-header__mob-right { display: none; }

  @media (max-width: 989px) {
    .pa-header__nav,
    .pa-header__util              { display: none; }
    .pa-header__row--utility      { grid-template-columns: auto 1fr auto; }
    .pa-header__row--logo         { display: none; }
    .pa-header__mob-left,
    .pa-header__mob-right         { display: flex; align-items: center; }
    .pa-header__mob-left          { gap: 18px; }
    .pa-header__mob-right         { gap: 18px; grid-column: 3; }
    .pa-header__mob-logo          { display: flex; justify-content: center; align-items: center; }
  }

  /* Push page content below the fixed header.
     80px is a safe fallback until JS measures the real height. */
  body { padding-top: var(--pa-header-height, 80px); }

  /* ================================================================
     PA Navigation Drawer
     ================================================================ */

  .pa-drawer-scrim {
    position: fixed;
    inset: 0;
    background: rgba(29, 29, 27, 0.55);
    z-index: 299;
    opacity: 0;
    pointer-events: none;
    transition: opacity 420ms ease;
  }
  .pa-drawer-scrim.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .pa-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100%;
    width: 520px;
    background: var(--pa-pine, #304b3d);
    color: var(--pa-ivory, #f9f8f4);
    z-index: 300;
    transform: translateX(-100%);
    transition: transform 420ms cubic-bezier(.22, 1, .36, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .pa-drawer.is-open { transform: translateX(0); }

  /* ── Tab bar ── */
  .pa-drawer__head {
    display: flex;
    align-items: center;
    gap: 28px;
    padding: 20px 32px;
    border-bottom: 1px solid rgba(249, 248, 244, 0.1);
    flex-shrink: 0;
  }

  .pa-drawer__tab {
    font-family: var(--font-body, 'Instrument Sans', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(249, 248, 244, 0.45);
    background: none;
    border: none;
    border-bottom: 1px solid transparent;
    padding: 0 0 4px;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .pa-drawer__tab.is-active {
    color: var(--pa-ivory, #f9f8f4);
    border-bottom-color: rgba(249, 248, 244, 0.55);
  }
  .pa-drawer__tab:hover { color: rgba(249, 248, 244, 0.8); }

  /* ── Scrollable body ── */
  .pa-drawer__body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  /* ── Nav section ── */
  .pa-drawer__section { display: none; }
  .pa-drawer__section.is-active { display: block; }

  .pa-drawer__nav { padding: 8px 0 24px; }

  .pa-drawer__nav-item {
    border-bottom: 1px solid rgba(249, 248, 244, 0.08);
  }

  .pa-drawer__nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 16px 32px;
    font-family: var(--font-display, 'EB Garamond', Georgia, serif);
    font-weight: 400;
    font-size: clamp(26px, 3.5vw, 34px);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--pa-ivory, #f9f8f4);
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: opacity 160ms ease;
  }
  .pa-drawer__nav-link:hover { opacity: 0.65; }

  .pa-drawer__chevron {
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform 280ms ease;
  }
  .pa-drawer__nav-item.is-open .pa-drawer__chevron { transform: rotate(180deg); }

  /* Sub-menu — max-height animation */
  .pa-drawer__sub {
    max-height: 0;
    overflow: hidden;
    transition: max-height 300ms ease;
    padding: 0 32px;
  }
  .pa-drawer__nav-item.is-open .pa-drawer__sub { max-height: 480px; }

  .pa-drawer__sub-inner {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-bottom: 20px;
  }

  .pa-drawer__sub-link {
    font-family: var(--font-body, 'Instrument Sans', sans-serif);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(249, 248, 244, 0.6);
    text-decoration: none;
    padding: 7px 0;
    transition: color 160ms ease;
  }
  .pa-drawer__sub-link:hover { color: var(--pa-ivory, #f9f8f4); }

  /* ── Search section ── */
  .pa-drawer__search { padding: 32px 32px 24px; }

  .pa-drawer__search-form {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid rgba(249, 248, 244, 0.25);
    padding-bottom: 14px;
  }

  .pa-drawer__search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-display, 'EB Garamond', Georgia, serif);
    font-size: clamp(24px, 3vw, 32px);
    color: var(--pa-ivory, #f9f8f4);
  }
  .pa-drawer__search-input::placeholder { color: rgba(249, 248, 244, 0.3); }

  .pa-drawer__search-btn {
    background: none;
    border: none;
    color: var(--pa-ivory, #f9f8f4);
    cursor: pointer;
    padding: 0;
    opacity: 0.55;
    transition: opacity 160ms ease;
    flex-shrink: 0;
  }
  .pa-drawer__search-btn:hover { opacity: 1; }

  /* ── Mobile footer (Account + Contact) ── */
  .pa-drawer__footer {
    display: none;
    align-items: center;
    gap: 32px;
    padding: 20px 32px;
    border-top: 1px solid rgba(249, 248, 244, 0.1);
    flex-shrink: 0;
  }

  .pa-drawer__footer-link {
    font-family: var(--font-body, 'Instrument Sans', sans-serif);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(249, 248, 244, 0.55);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .pa-drawer__footer-link:hover { color: var(--pa-ivory, #f9f8f4); }

  @media (max-width: 989px) {
    .pa-drawer       { width: 86vw; }
    .pa-drawer__footer { display: flex; }
  }
</style>

<div id="pa-site-header" class="pa-header" role="banner">
  <div class="pa-header__inner">

    <!-- ── Row 1: utility nav ── -->
    <div class="pa-header__row--utility">

      <!-- Mobile: hamburger + search -->
      <div class="pa-header__mob-left">
        <button
          class="pa-header__link"
          type="button"
          aria-label="{{ 'sections.header.menu' | t }}"
          onclick="paOpenDrawer('nav')"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="4" x2="20" y1="6"  y2="6"/>
            <line x1="4" x2="20" y1="12" y2="12"/>
            <line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
        </button>
        <button type="button" class="pa-header__link" aria-label="{{ 'general.search.search' | t }}" onclick="paOpenDrawer('search')">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </button>
      </div>

      <!-- Mobile: centred secondary logo -->
      <div class="pa-header__mob-logo">
        <a href="{{ routes.root_url }}" class="pa-header__logo-link">
          <img src="{{ 'secondary-logo-2-cocoa.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--dark"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
          <img src="{{ 'secondary-logo-2-ivory.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--light"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
        </a>
      </div>

      <!-- Desktop: primary nav + search -->
      <nav class="pa-header__nav" aria-label="Primary navigation">
        {%- for link in nav_links -%}
          <a
            href="{{ link.url }}"
            class="pa-header__link"
            {% if link.active %}aria-current="page"{% endif %}
          >{{ link.title }}</a>
        {%- endfor -%}

        <button type="button" class="pa-header__link" aria-label="{{ 'general.search.search' | t }}" onclick="paOpenDrawer('search')">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
          Search
        </button>
      </nav>

      <!-- Desktop: utility + cart -->
      <div class="pa-header__util">
        <a href="{{ routes.root_url }}pages/contact" class="pa-header__link">Contact</a>

        {%- if shop.customer_accounts_enabled -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="pa-header__link"
            rel="nofollow"
          >Account</a>
        {%- endif -%}

        <a href="/pages/wishlist" class="pa-header__link">Wishlist (0)</a>

        <a href="{{ routes.cart_url }}" class="pa-header__link" id="pa-cart-icon">
          Bag{%- if cart.item_count > 0 -%}<span class="pa-header__cart-count"> ({{ cart.item_count }})</span>{%- endif -%}
        </a>
      </div>

      <!-- Mobile: wishlist + cart -->
      <div class="pa-header__mob-right">
        <a href="/pages/wishlist" class="pa-header__link" aria-label="Wishlist">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 1.5C10.5 3.5 9.26 3 7.5 3A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
          </svg>
        </a>
        <a href="{{ routes.cart_url }}" class="pa-header__link" aria-label="{{ 'templates.cart.cart' | t }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="pa-header__cart-count" aria-hidden="true">({{ cart.item_count }})</span>
          {%- endif -%}
        </a>
      </div>

    </div><!-- /row--utility -->

    <!-- ── Row 2: centred logo ── -->
    <div class="pa-header__row--logo">
      {%- if request.page_type == 'index' -%}
        <h1 class="pa-header__logo-wrap">
      {%- else -%}
        <div class="pa-header__logo-wrap">
      {%- endif -%}

        <a href="{{ routes.root_url }}" class="pa-header__logo-link">
          <img src="{{ 'primary-logo-cocoa.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--dark"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
          <img src="{{ 'primary-logo-ivory.svg' | asset_url }}"
               class="pa-header__logo pa-header__logo--light"
               alt="{{ shop.name | escape }}"
               height="18"
               width="auto">
        </a>

      {%- if request.page_type == 'index' -%}
        </h1>
      {%- else -%}
        </div>
      {%- endif -%}
    </div><!-- /row--logo -->

  </div><!-- /pa-header__inner -->
</div><!-- /pa-header -->

{%- comment -%}
  Navigation Drawer — reads from the same main-menu linklist as the header nav.
  Sub-menus are driven by nested links in Shopify Admin → Online Store → Navigation.

  Recommended main-menu structure to create in the Shopify admin:
  ┌─ Shop
  │   ├─ New arrivals          → /collections/new-arrivals
  │   ├─ Perfume               → /collections/perfume
  │   ├─ Home fragrance        → /collections/home-fragrance
  │   ├─ Candles               → /collections/candles
  │   └─ All products          → /collections/all
  ├─ Brands
  │   ├─ Atelier Maison Noir   → /collections/atelier-maison-noir
  │   ├─ House of Velour       → /collections/house-of-velour
  │   ├─ Studio Linnea         → /collections/studio-linnea
  │   ├─ Maison du Nord        → /collections/maison-du-nord
  │   └─ All brands            → /collections/all-brands
  └─ Discover
      ├─ The journal           -> /blogs/journal
      ├─ House studies         → /blogs/journal/tagged/house-study
      ├─ Field notes           → /blogs/journal/tagged/field-notes
      └─ About us              → /pages/about
{%- endcomment -%}

<!-- ── Scrim overlay ── -->
<div class="pa-drawer-scrim" id="pa-drawer-scrim" aria-hidden="true"></div>

<!-- ── Navigation Drawer ── -->
<div class="pa-drawer" id="pa-drawer" role="dialog" aria-modal="true" aria-label="Navigation" aria-hidden="true">

  <div class="pa-drawer__head">
    <button class="pa-drawer__tab is-active" data-tab="nav" onclick="paDrawerTab('nav')">Menu</button>
    <button class="pa-drawer__tab" data-tab="search" onclick="paDrawerTab('search')">Search</button>
  </div>

  <div class="pa-drawer__body">

    <!-- Nav section -->
    <div class="pa-drawer__section is-active" id="pa-drawer-nav">
      <nav class="pa-drawer__nav" aria-label="Site navigation">
        {%- for link in nav_links -%}
          <div class="pa-drawer__nav-item">
            {%- if link.links != empty -%}
              <button
                class="pa-drawer__nav-link"
                type="button"
                onclick="paDrawerToggle(this)"
                aria-expanded="false"
              >
                {{- link.title -}}
                <svg class="pa-drawer__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </button>
              <div class="pa-drawer__sub">
                <div class="pa-drawer__sub-inner">
                  {%- for sub in link.links -%}
                    <a href="{{ sub.url }}" class="pa-drawer__sub-link">{{ sub.title }}</a>
                  {%- endfor -%}
                </div>
              </div>
            {%- else -%}
              <a href="{{ link.url }}" class="pa-drawer__nav-link"
                 {% if link.active %}aria-current="page"{% endif %}>
                {{- link.title -}}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>
    </div>

    <!-- Search section -->
    <div class="pa-drawer__section" id="pa-drawer-search">
      <div class="pa-drawer__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="hidden" name="type" value="product">
          <div class="pa-drawer__search-form">
            <input
              id="pa-drawer-search-input"
              class="pa-drawer__search-input"
              type="search"
              name="q"
              placeholder="Search fragrances, houses, notes…"
              autocomplete="off"
              aria-label="{{ 'general.search.search' | t }}"
            >
            <button type="submit" class="pa-drawer__search-btn" aria-label="{{ 'general.search.search' | t }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="1.5"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.3-4.3"/>
              </svg>
            </button>
          </div>
        </form>
      </div>
    </div>

  </div><!-- /pa-drawer__body -->

  <!-- Mobile footer: Account + Contact -->
  <div class="pa-drawer__footer">
    {%- if shop.customer_accounts_enabled -%}
      <a
        href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
        class="pa-drawer__footer-link"
        rel="nofollow"
      >Account</a>
    {%- endif -%}
    <a href="{{ routes.root_url }}pages/contact" class="pa-drawer__footer-link">Contact</a>
  </div>

</div><!-- /pa-drawer -->

<script>
  (function () {
    var header = document.getElementById('pa-site-header');
    if (!header) return;

    function setHeight() {
      var h = header.offsetHeight + 'px';
      document.documentElement.style.setProperty('--pa-header-height', h);
      document.documentElement.style.setProperty('--header-height', h);
    }

    function onScroll() {
      header.classList.toggle('is-scrolled', window.scrollY > 10);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', setHeight);
    onScroll();
    setHeight();
  })();
</script>

<script>
  (function () {
    var drawer = document.getElementById('pa-drawer');
    var scrim  = document.getElementById('pa-drawer-scrim');
    if (!drawer || !scrim) return;

    function openDrawer(tab) {
      drawer.classList.add('is-open');
      scrim.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (tab) paDrawerTab(tab);
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      scrim.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function paDrawerTab(tab) {
      drawer.querySelectorAll('.pa-drawer__tab').forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.tab === tab);
      });
      drawer.querySelectorAll('.pa-drawer__section').forEach(function (sec) {
        sec.classList.toggle('is-active', sec.id === 'pa-drawer-' + tab);
      });
      if (tab === 'search') {
        setTimeout(function () {
          var input = document.getElementById('pa-drawer-search-input');
          if (input) input.focus();
        }, 60);
      }
    }

    function paDrawerToggle(btn) {
      var item   = btn.closest('.pa-drawer__nav-item');
      var isOpen = item.classList.contains('is-open');
      drawer.querySelectorAll('.pa-drawer__nav-item.is-open').forEach(function (el) {
        el.classList.remove('is-open');
        var t = el.querySelector('[aria-expanded]');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    }

    scrim.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeDrawer();
    });

    window.paOpenDrawer  = openDrawer;
    window.paCloseDrawer = closeDrawer;
    window.paDrawerTab   = paDrawerTab;
    window.paDrawerToggle = paDrawerToggle;
  })();
</script>

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {%- assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' -%}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

