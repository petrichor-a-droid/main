{% comment %}
  Petrichor Atelier — Featured Collection
  "In the atelier" — 4-column product grid with eyebrow/heading header and
  "The full edit →" view-all link. Mirrors the featured grid in Storefront.jsx.
{% endcomment %}

{{ 'pa-product-card.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign col        = collections[section.settings.collection]
  assign prod_limit = section.settings.products_to_show | default: 4
-%}

<style>
  #shopify-section-{{ section.id }} .pa-fc {
    padding: 120px 0 80px;
    background: var(--bg-canvas);
  }

  #shopify-section-{{ section.id }} .pa-fc__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  /* ── Header row ── */
  #shopify-section-{{ section.id }} .pa-fc__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 56px;
    gap: 24px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .pa-fc__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .pa-fc__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: clamp(40px, 5vw, 64px);
    line-height: var(--lh-heading);
    letter-spacing: -0.014em;
    margin: 14px 0 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-fc__heading em,
  #shopify-section-{{ section.id }} .pa-fc__heading i {
    font-family: var(--font-editorial);
    font-style: italic;
  }

  #shopify-section-{{ section.id }} .pa-fc__view-all {
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-1);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    border-bottom: 1px solid var(--fg-1);
    padding-bottom: 4px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity var(--dur-base) var(--ease-soft);
  }

  #shopify-section-{{ section.id }} .pa-fc__view-all:hover {
    opacity: 0.55;
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .pa-fc {
      padding: 80px 0 56px;
    }
    #shopify-section-{{ section.id }} .pa-fc__inner {
      padding: 0 var(--gutter-mobile, 20px);
    }
    #shopify-section-{{ section.id }} .pa-fc__header {
      margin-bottom: 40px;
    }
  }
</style>

<div class="pa-fc">
  <div class="pa-fc__inner">

    <div class="pa-fc__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="pa-fc__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="pa-fc__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- if section.settings.view_all_label != blank -%}
        {%- assign view_url = section.settings.view_all_url | default: col.url | default: routes.collections_url -%}
        <a href="{{ view_url }}" class="pa-fc__view-all">
          {{- section.settings.view_all_label | escape }}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="pa-fc__grid">
      {%- for product in col.products limit: prod_limit -%}
        {%- render 'pa-product-card', card_product: product, loading: 'lazy' -%}
      {%- else -%}
        {%- for i in (1..prod_limit) -%}
          {%- render 'pa-product-card' -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "PA — Featured Collection",
  "tag": "section",
  "class": "section-pa-featured-collection",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 2,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In the atelier"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Four pieces we keep <em>reaching for.</em>",
      "info": "Use italic in the editor for the editorial serif style."
    },
    {
      "type": "header",
      "content": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Link label",
      "default": "The full edit"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Link URL",
      "info": "Defaults to the selected collection URL if left blank."
    }
  ],
  "presets": [
    {
      "name": "PA — Featured Collection"
    }
  ]
}
{% endschema %}

