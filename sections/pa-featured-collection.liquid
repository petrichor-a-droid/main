{% comment %}
  Petrichor Atelier — Featured Collection
  "In the atelier" — 4-column product grid with eyebrow/heading header and
  "The full edit →" view-all link. Mirrors the featured grid in Storefront.jsx.
{% endcomment %}

{%- liquid
  assign col        = collections[section.settings.collection]
  assign prod_limit = section.settings.products_to_show | default: 4
-%}

<style>
  #shopify-section-{{ section.id }} .pa-fc {
    padding: 120px 0 80px;
    background: var(--bg-canvas);
  }

  #shopify-section-{{ section.id }} .pa-fc__inner {
    max-width: var(--max-content, 1280px);
    margin: 0 auto;
    padding: 0 var(--gutter, 40px);
  }

  /* ── Header row ── */
  #shopify-section-{{ section.id }} .pa-fc__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 56px;
    gap: 24px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .pa-fc__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-medium);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .pa-fc__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: clamp(40px, 5vw, 64px);
    line-height: var(--lh-heading);
    letter-spacing: -0.014em;
    margin: 14px 0 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-fc__heading em,
  #shopify-section-{{ section.id }} .pa-fc__heading i {
    font-family: var(--font-editorial);
    font-style: italic;
  }

  #shopify-section-{{ section.id }} .pa-fc__view-all {
    font-family: var(--font-body);
    font-size: var(--t-eyebrow);
    font-weight: var(--fw-semibold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-1);
    text-decoration: none;
    border-bottom: 1px solid var(--fg-1);
    padding-bottom: 4px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity var(--dur-base) var(--ease-soft);
  }

  #shopify-section-{{ section.id }} .pa-fc__view-all:hover {
    opacity: 0.55;
  }

  /* ── Product grid ── */
  #shopify-section-{{ section.id }} .pa-fc__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 28px;
  }

  /* ── Product card ── */
  #shopify-section-{{ section.id }} .pa-fc__card {
    display: block;
    text-decoration: none;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-fc__card-img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: var(--bg-surface);
  }

  #shopify-section-{{ section.id }} .pa-fc__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  #shopify-section-{{ section.id }} .pa-fc__card:hover .pa-fc__card-img {
    transform: scale(1.03);
  }

  #shopify-section-{{ section.id }} .pa-fc__card-placeholder {
    width: 100%;
    height: 100%;
    display: block;
    background: var(--bg-surface);
  }

  #shopify-section-{{ section.id }} .pa-fc__card-body {
    padding-top: 16px;
  }

  #shopify-section-{{ section.id }} .pa-fc__card-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .pa-fc__card-vendor {
    display: block;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: var(--fw-medium);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 4px;
  }

  #shopify-section-{{ section.id }} .pa-fc__card-title {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: var(--ls-heading);
    margin: 0;
    color: var(--fg-1);
  }

  #shopify-section-{{ section.id }} .pa-fc__card-price {
    font-family: var(--font-body);
    font-size: var(--t-body-sm);
    color: var(--fg-1);
    white-space: nowrap;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .pa-fc__card-price s {
    opacity: 0.5;
    margin-left: 6px;
  }

  #shopify-section-{{ section.id }} .pa-fc__card-notes {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--fg-2);
    margin: 6px 0 0;
    line-height: 1.4;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .pa-fc__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
    }
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .pa-fc {
      padding: 80px 0 56px;
    }
    #shopify-section-{{ section.id }} .pa-fc__inner {
      padding: 0 var(--gutter-mobile, 20px);
    }
    #shopify-section-{{ section.id }} .pa-fc__header {
      margin-bottom: 40px;
    }
  }
</style>

<div class="pa-fc">
  <div class="pa-fc__inner">

    <div class="pa-fc__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <span class="pa-fc__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="pa-fc__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      {%- if section.settings.view_all_label != blank -%}
        {%- assign view_url = section.settings.view_all_url | default: col.url | default: routes.collections_url -%}
        <a href="{{ view_url }}" class="pa-fc__view-all">
          {{- section.settings.view_all_label | escape }} &rarr;
        </a>
      {%- endif -%}
    </div>

    <div class="pa-fc__grid">
      {%- for product in col.products limit: prod_limit -%}
        <a href="{{ product.url }}" class="pa-fc__card">
          <div class="pa-fc__card-img-wrap">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  class: 'pa-fc__card-img',
                  widths: '400, 600, 800',
                  sizes: '(max-width: 749px) calc(50vw - 30px), (max-width: 989px) calc(50vw - 54px), 25vw',
                  loading: 'lazy',
                  alt: product.featured_image.alt | default: product.title | escape
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'pa-fc__card-placeholder' }}
            {%- endif -%}
          </div>

          <div class="pa-fc__card-body">
            <div class="pa-fc__card-meta">
              <div>
                {%- if product.vendor != blank -%}
                  <span class="pa-fc__card-vendor">{{ product.vendor | escape }}</span>
                {%- endif -%}
                <h3 class="pa-fc__card-title">{{ product.title | escape }}</h3>
              </div>
              <div class="pa-fc__card-price">
                {%- if product.compare_at_price > product.price -%}
                  {{ product.price | money }}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </div>
            </div>
            {%- assign card_notes = product.metafields.custom.notes.value -%}
            {%- if card_notes != blank -%}
              <p class="pa-fc__card-notes">{{ card_notes | escape }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- else -%}
        {%- comment -%} No products — show placeholder cards {%- endcomment -%}
        {%- for i in (1..prod_limit) -%}
          <div class="pa-fc__card">
            <div class="pa-fc__card-img-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'pa-fc__card-placeholder' }}
            </div>
            <div class="pa-fc__card-body">
              <div class="pa-fc__card-meta">
                <div>
                  <span class="pa-fc__card-vendor">Vendor</span>
                  <h3 class="pa-fc__card-title">Product name</h3>
                </div>
                <div class="pa-fc__card-price">{{ 1999 | money }}</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "PA — Featured Collection",
  "tag": "section",
  "class": "section-pa-featured-collection",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 2,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "In the atelier"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Four pieces we keep <em>reaching for.</em>",
      "info": "Use italic in the editor for the editorial serif style."
    },
    {
      "type": "header",
      "content": "View all link"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Link label",
      "default": "The full edit"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "Link URL",
      "info": "Defaults to the selected collection URL if left blank."
    }
  ],
  "presets": [
    {
      "name": "PA — Featured Collection"
    }
  ]
}
{% endschema %}

