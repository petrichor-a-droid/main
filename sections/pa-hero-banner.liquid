{{ 'petrichor-tokens.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .pa-hero {
    position: relative;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--bg-inverse-deep);
  }
  #shopify-section-{{ section.id }} .pa-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .pa-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
    display: block;
  }
  #shopify-section-{{ section.id }} .pa-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(29, 29, 27, 0.55));
    z-index: 1;
  }
  #shopify-section-{{ section.id }} .pa-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-12) var(--gutter) var(--space-10);
    max-width: var(--max-content);
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .pa-hero__eyebrow {
    font-family: var(--font-body);
    font-weight: var(--fw-medium);
    font-size: var(--t-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--pa-sage);
    display: block;
    margin-bottom: var(--space-5);
  }
  #shopify-section-{{ section.id }} .pa-hero__heading {
    font-family: var(--font-display);
    font-weight: var(--fw-regular);
    font-size: var(--t-h1);
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-heading);
    color: var(--pa-ivory);
    margin: 0 0 var(--space-5);
    max-width: 14ch;
  }
  #shopify-section-{{ section.id }} .pa-hero__heading em {
    font-family: var(--font-editorial);
    font-style: italic;
  }
  #shopify-section-{{ section.id }} .pa-hero__subhead {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--fw-regular);
    font-size: clamp(18px, 2.2vw, 26px);
    line-height: var(--lh-subhead);
    color: var(--fg-on-inverse-2, color-mix(in srgb, var(--pa-ivory) 75%, var(--pa-sage)));
    margin: 0 0 var(--space-8);
    max-width: 44ch;
  }
  #shopify-section-{{ section.id }} .pa-hero__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: var(--fw-semibold);
    font-size: var(--t-cta);
    letter-spacing: var(--ls-cta);
    text-transform: uppercase;
    color: var(--pa-ivory);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--pa-ivory) 45%, transparent);
    padding-bottom: 3px;
    transition: border-color var(--dur-base) var(--ease-out);
  }
  #shopify-section-{{ section.id }} .pa-hero__cta:hover {
    border-color: var(--pa-ivory);
  }
  #shopify-section-{{ section.id }} .pa-hero__cta + .pa-hero__cta {
    margin-left: var(--space-7);
    color: var(--pa-mint);
    border-color: color-mix(in srgb, var(--pa-mint) 45%, transparent);
  }
  #shopify-section-{{ section.id }} .pa-hero__cta + .pa-hero__cta:hover {
    border-color: var(--pa-mint);
  }
  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .pa-hero__content {
      padding: var(--space-10) var(--gutter-mobile) var(--space-9);
    }
    #shopify-section-{{ section.id }} .pa-hero__heading {
      max-width: 100%;
    }
  }
</style>

<div class="pa-hero">
  {%- if section.settings.image != blank -%}
    <div class="pa-hero__media">
      {{
        section.settings.image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000',
          sizes: '100vw'
      }}
    </div>
    <div class="pa-hero__overlay"></div>
  {%- endif -%}

  <div class="pa-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="pa-hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="pa-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="pa-hero__subhead">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" class="pa-hero__cta">
        {{- section.settings.cta_label -}}
      </a>
    {%- endif -%}

    {%- if section.settings.cta_2_label != blank and section.settings.cta_2_url != blank -%}
      <a href="{{ section.settings.cta_2_url }}" class="pa-hero__cta">
        {{- section.settings.cta_2_label -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "PA — Hero banner",
  "tag": "section",
  "class": "section-pa-hero",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point",
      "options": [
        { "value": "center center", "label": "Centre" },
        { "value": "top center",    "label": "Top" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "center left",   "label": "Left" },
        { "value": "center right",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height (px)",
      "min": 400,
      "max": 900,
      "step": 50,
      "default": 700
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "IN THE ATELIER"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Fragrance<br><em>deeply felt.</em></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A curation of rare houses, brought home to Australia."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Explore the edit"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA (optional)"
    },
    {
      "type": "text",
      "id": "cta_2_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_2_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "PA — Hero banner"
    }
  ]
}
{% endschema %}
