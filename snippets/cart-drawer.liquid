{% comment %}
  Petrichor Atelier — Cart Drawer
  Slides in from the right. Ivory panel, ink scrim overlay.
  Dawn's cart.js machinery (cart-drawer element, form IDs, quantity-input, cart-remove-button)
  is kept intact for AJAX cart updates. Only the visual layer is replaced.
{% endcomment %}

{{ 'pa-cart-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer { visibility: hidden; }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer">

    <div id="CartDrawer-Overlay" class="pa-cd__overlay"></div>

    <div
      class="drawer__inner pa-cd__panel"
      role="dialog"
      aria-modal="true"
      aria-label="Your basket"
      tabindex="-1"
    >

      {%- comment -%} ── Head ── {%- endcomment -%}
      <div class="pa-cd__head">
        <div>
          <p class="pa-cd__eyebrow">The basket</p>
          <p class="pa-cd__count">
            {{ cart.item_count }} {%- if cart.item_count == 1 -%}item{%- else -%}items{%- endif -%}
          </p>
        </div>
        <button
          class="pa-cd__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {%- comment -%} ── Items ── {%- endcomment -%}
      <cart-drawer-items{% if cart == empty %} class="is-empty"{% endif %}>
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="pa-cd__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="pa-cd__items js-contents">

            {%- if cart == empty -%}
              <div class="pa-cd__empty drawer__inner-empty">
                <p class="pa-cd__empty-text">Nothing here yet —<br>that's part of the discovery.</p>
                <a
                  href="{{ routes.all_products_collection_url }}"
                  class="pa-cd__continue"
                  onclick="event.preventDefault(); this.closest('cart-drawer').close()"
                >Continue browsing</a>
              </div>
            {%- else -%}
              {%- for item in cart.items -%}
                <div id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="pa-cd__item">

                  <a href="{{ item.url }}" class="pa-cd__item-img" tabindex="-1" aria-hidden="true">
                    {%- if item.image -%}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | escape }}"
                        loading="lazy"
                        width="78"
                        height="{{ 78 | divided_by: item.image.aspect_ratio | ceil }}"
                      >
                    {%- endif -%}
                  </a>

                  <div class="pa-cd__item-info">
                    {%- if item.product.vendor != blank -%}
                      <span class="pa-cd__item-vendor">{{ item.product.vendor | escape }}</span>
                    {%- endif -%}
                    <a href="{{ item.url }}" class="pa-cd__item-title">{{ item.product.title | escape }}</a>

                    {%- unless item.product.has_only_default_variant -%}
                      <div class="pa-cd__item-variant">
                        {%- for option in item.options_with_values -%}
                          {{ option.value }}{%- unless forloop.last %}, {%- endunless -%}
                        {%- endfor -%}
                      </div>
                    {%- endunless -%}

                    <div class="pa-cd__item-actions">
                      <quantity-input class="pa-cd__qty">
                        <button class="pa-cd__qty-btn" name="minus" type="button">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                          <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}</span>
                        </button>
                        <input
                          class="pa-cd__qty-input quantity__input"
                          type="number"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          min="0"
                          data-quantity-variant-id="{{ item.variant.id }}"
                          data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                          data-min="{{ item.variant.quantity_rule.min }}"
                          {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
                          step="{{ item.variant.quantity_rule.increment }}"
                          id="Drawer-quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                        >
                        <button class="pa-cd__qty-btn" name="plus" type="button">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                          <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}</span>
                        </button>
                      </quantity-input>

                      <cart-remove-button
                        id="CartDrawer-Remove-{{ item.index | plus: 1 }}"
                        data-index="{{ item.index | plus: 1 }}"
                      >
                        <button
                          type="button"
                          class="pa-cd__remove"
                          aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                          data-variant-id="{{ item.variant.id }}"
                        >Remove</button>
                      </cart-remove-button>
                    </div>

                    <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert">
                      <small class="cart-item__error-text"></small>
                    </div>
                  </div>

                  <div class="pa-cd__item-price">
                    {%- render 'loading-spinner' -%}
                    {%- if item.original_line_price != item.final_line_price -%}
                      <s>{{ item.original_line_price | money }}</s>
                      <span>{{ item.final_line_price | money }}</span>
                    {%- else -%}
                      <span>{{ item.original_line_price | money }}</span>
                    {%- endif -%}
                  </div>

                </div>
              {%- endfor -%}
            {%- endif -%}

            <div id="CartDrawer-CartErrors" class="pa-cd__errors" role="alert"></div>
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
          </div>
        </form>
      </cart-drawer-items>

      {%- comment -%} ── Footer ── {%- endcomment -%}
      <div class="pa-cd__footer">
        {%- if cart.cart_level_discount_applications.size > 0 -%}
          <ul class="pa-cd__discounts list-unstyled" role="list">
            {%- for discount in cart.cart_level_discount_applications -%}
              <li class="pa-cd__discount">
                {{ discount.title | escape }} (-{{ discount.total_allocated_amount | money }})
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="pa-cd__subtotal" role="status">
          <span class="pa-cd__subtotal-label">Subtotal</span>
          <span class="pa-cd__subtotal-value">{{ cart.total_price | money }}</span>
        </div>
        <p class="pa-cd__shipping-note">Complimentary shipping within Australia.</p>

        <button
          type="submit"
          id="CartDrawer-Checkout"
          class="pa-cd__checkout"
          name="checkout"
          form="CartDrawer-Form"
          {% if cart == empty %}disabled{% endif %}
        >Step to checkout
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      </div>

    </div>
  </div>
</cart-drawer>
